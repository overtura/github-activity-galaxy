{
  "name": "GitHub Activity Galaxy",
  "kind": "interactive-3d-activity-map",
  "runtime": "React + Vite + React Three Fiber",
  "language": "ko",
  "goal": "GitHub 활동을 밝은 3D 운영 지도로 시각화하고, 자동 PR로 데이터 모델, 접근성, 시각 품질을 안전하게 개선한다.",
  "allowedChangeScope": [
    "src/**",
    "DESIGN.md",
    "README.md",
    "docs/**",
    ".github/workflows/**",
    ".github/prompts/**",
    "self-improvement/**",
    "scripts/**",
    "package.json"
  ],
  "blockedChangeScope": [
    ".env*",
    "*.pem",
    "*.key",
    ".npmrc",
    "실제 GitHub token",
    "private activity dump",
    "개인 인증 정보"
  ],
  "qualityGates": [
    "pnpm self-improve:guard",
    "pnpm check"
  ]
}
