{
  "schemaVersion": 1,
  "controlPlane": "okorion/self-improving-maintainer-bot",
  "name": "GitHub Activity Galaxy",
  "kind": "interactive-3d-activity-map",
  "runtime": "React + Vite + React Three Fiber",
  "language": "ko",
  "goal": "GitHub 활동을 밝은 3D 운영 지도로 시각화하고, 중앙 maintainer bot이 PR 단위로 데이터 모델, 접근성, 시각 품질을 안전하게 개선한다.",
  "automation": {
    "defaultRiskLevel": "R1",
    "maxAutoMergeRiskLevel": "R1",
    "r3Mode": "draft_or_proposal_only",
    "autoMerge": false,
    "verifyCommands": [
      "pnpm install --frozen-lockfile || pnpm install",
      "pnpm check"
    ],
    "allowPaths": [
      "README.md",
      "DESIGN.md",
      "docs/**",
      "maintainer-bot/**",
      "src/**"
    ],
    "denyPaths": [
      ".github/workflows/**",
      "CODEOWNERS",
      ".env*",
      ".npmrc",
      "infra/**",
      "terraform/**",
      "k8s/**",
      "migrations/**",
      "**/auth/**",
      "**/security/**",
      "*.pem",
      "*.key",
      "*token*",
      "*credential*"
    ],
    "maxFiles": 12,
    "maxLines": 300
  }
}
